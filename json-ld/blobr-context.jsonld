    "targetRoas": "blobr:targetRoas",
    "amountMicros": "blobr:budgetAmount",
    "metrics": "blobr:campaignMetrics",
    "impressions": "blobr:impressions",
    "clicks": "blobr:clicks",
    "conversions": "blobr:conversions",
